  <!-- ======================== RELEASE COMPILE SETTINGS ======================== -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <ClCompile>
      <!-- Original: /G5 /MT /W4 /GX /Zd /O2 -->
      <!-- /G5 dropped (Pentium-specific, not in modern MSVC) -->
      <!-- /GX replaced by /EHsc -->
      <!-- /Zd replaced by /Zi (old line-number-only debug format removed) -->
      <!-- /YX removed (automatic PCH detection removed in VS2005+) -->
      <!-- Unity: group only files from the same folder so per-subsystem headers
           (client.h, server.h, qcommon.h) are each used by exactly one batch -->
      <CombineFilesOnlyFromTheSameFolder>true</CombineFilesOnlyFromTheSameFolder>
      <Optimization>MaxSpeed</Optimization>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <PreprocessorDefinitions>WIN32;NDEBUG;_WINDOWS;_CRT_SECURE_NO_WARNINGS;_WINSOCK_DEPRECATED_NO_WARNINGS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <ExceptionHandling>Sync</ExceptionHandling>
      <WarningLevel>Level3</WarningLevel>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
      <AdditionalIncludeDirectories>$(SolutionDir);..\..\client;..\..\game;..\..\qcommon;..\..\server;..\..\win32;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <!-- Suppress noisy-but-harmless VC6-era warnings -->
      <DisableSpecificWarnings>4244;4305;4018;4267;4996;4311;4312;4133;4028;4273;%(DisableSpecificWarnings)</DisableSpecificWarnings>
      <MultiProcessorCompilation>true</MultiProcessorCompilation>
      <!-- PCH disabled for the exe: source files span client/, server/, qcommon/, win32/ with
           different umbrella headers. q_shared.h (the only truly universal header) has no
           include guards, making ForcedIncludeFiles unsafe. PCH is on the four DLL projects. -->
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
    </ClCompile>
    <ResourceCompile>
      <PreprocessorDefinitions>NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>..\..\win32;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ResourceCompile>
